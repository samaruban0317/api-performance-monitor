# ---------------------------------------------------------------------------
# API Performance Monitor — environment configuration
# Copy this file to ".env" and adjust as needed.
# ---------------------------------------------------------------------------

# Flask
FLASK_HOST=0.0.0.0
FLASK_PORT=5000
FLASK_DEBUG=false
SECRET_KEY=change-me-in-production

# Path to the SQLite database file
DATABASE_PATH=data/monitor.db

# Path to the monitored-endpoints config file
CONFIG_PATH=config.yaml

# Background probe scheduler (set to false to run the web app without probing)
ENABLE_SCHEDULER=true

# How many days of metric samples to keep (older rows are pruned hourly)
RETENTION_DAYS=30
